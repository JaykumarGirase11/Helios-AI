# ──────────────────────────────────────────────────
# HELIOS AI - Backend Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────

# ─── Firebase (REQUIRED) ─────────────────────────
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
FIREBASE_API_KEY=AIzaSy_YOUR_API_KEY
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID

# ─── Groq AI (REQUIRED for LLM & Vision) ─────────
# Get free API key at: https://console.groq.com
# Models used: llama3-70b-8192, llama-3.2-90b-vision-preview
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY

# ─── Hugging Face (OPTIONAL - image models) ──────
HUGGING_FACE_TOKEN=hf_YOUR_TOKEN

# ─── Together.ai (OPTIONAL - Stable Diffusion) ───
# For advanced Virtual EL generation
TOGETHER_API_KEY=YOUR_TOGETHER_KEY

# ─── Replicate (OPTIONAL - Pix2Pix model) ────────
# For alternative image generation
REPLICATE_API_KEY=YOUR_REPLICATE_KEY

# ─── Supabase (OPTIONAL - AI result persistence) ─
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJ_YOUR_KEY

# ─── CORS (set to your frontend URL) ─────────────
ALLOWED_ORIGINS=http://localhost:5173
